#!/usr/bin/env python3

import math
import os
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path

import cairo
import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
gi.require_version("PangoCairo", "1.0")

from gi.repository import Gdk, GLib, Gtk  # noqa: E402


TOOL_LABELS = {
    "pencil": "Карандаш",
    "marker": "Маркер",
    "square": "Квадрат",
    "circle": "Круг",
    "arrow": "Стрелка",
}

TOOL_ORDER = ["pencil", "marker", "square", "circle", "arrow"]


@dataclass
class Rect:
    x: float
    y: float
    width: float
    height: float

    def normalized(self):
        x1 = min(self.x, self.x + self.width)
        y1 = min(self.y, self.y + self.height)
        x2 = max(self.x, self.x + self.width)
        y2 = max(self.y, self.y + self.height)
        return Rect(x1, y1, x2 - x1, y2 - y1)

    def contains(self, x, y):
        rect = self.normalized()
        return (
            rect.x <= x <= rect.x + rect.width
            and rect.y <= y <= rect.y + rect.height
        )


@dataclass
class Annotation:
    tool: str
    start: tuple[float, float]
    end: tuple[float, float]
    color: tuple[float, float, float, float]
    points: list[tuple[float, float]] = field(default_factory=list)


class ScreenshotWindow(Gtk.Window):
    def __init__(self, mode: str):
        super().__init__(title="Скриншот")
        self.mode = mode
        self.current_tool = "pencil"
        self.draw_color = Gdk.RGBA(0.97, 0.35, 0.27, 1.0)
        self.drag_action = None
        self.selection_start = None
        self.selection = None
        self.annotations = []
        self.preview_annotation = None
        self.pointer_pos = self.get_pointer_position()
        self.screenshot = self.capture_root()
        if self.screenshot is None:
            self.fail_and_exit(
                "Не удалось получить снимок экрана. Новый интерфейс работает после входа в Xorg."
            )
            return

        self.screen_width = self.screenshot.get_width()
        self.screen_height = self.screenshot.get_height()
        if self.mode == "full":
            self.selection = Rect(0, 0, self.screen_width, self.screen_height)

        self.set_decorated(False)
        self.set_keep_above(True)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_type_hint(Gdk.WindowTypeHint.SPLASHSCREEN)
        self.set_resizable(False)
        self.stick()
        self.set_default_size(self.screen_width, self.screen_height)
        self.move(0, 0)
        self.connect("destroy", Gtk.main_quit)
        self.connect("key-press-event", self.on_key_press)
        self.connect("realize", self.on_realize)

        overlay = Gtk.Overlay()
        self.add(overlay)

        self.canvas = Gtk.DrawingArea()
        self.canvas.set_events(
            Gdk.EventMask.BUTTON_PRESS_MASK
            | Gdk.EventMask.BUTTON_RELEASE_MASK
            | Gdk.EventMask.POINTER_MOTION_MASK
        )
        self.canvas.connect("draw", self.on_draw)
        self.canvas.connect("button-press-event", self.on_button_press)
        self.canvas.connect("button-release-event", self.on_button_release)
        self.canvas.connect("motion-notify-event", self.on_motion_notify)
        overlay.add(self.canvas)

        self.toolbar = self.build_toolbar()
        self.toolbar.set_halign(Gtk.Align.CENTER)
        self.toolbar.set_valign(Gtk.Align.START)
        self.toolbar.set_margin_top(16)
        overlay.add_overlay(self.toolbar)

        self.hint_label = Gtk.Label()
        self.hint_label.set_halign(Gtk.Align.START)
        self.hint_label.set_valign(Gtk.Align.END)
        self.hint_label.set_margin_start(20)
        self.hint_label.set_margin_bottom(20)
        self.hint_label.set_xalign(0.0)
        self.hint_label.get_style_context().add_class("hint")
        overlay.add_overlay(self.hint_label)

        self.apply_css()
        self.update_toolbar()
        self.update_hint()
        self.show_all()
        self.tool_popover.popdown()
        GLib.idle_add(self.cover_virtual_screen)
        self.update_cursor()

    def build_toolbar(self):
        toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        toolbar.set_name("toolbar")
        toolbar.set_margin_start(16)
        toolbar.set_margin_end(16)
        toolbar.set_margin_bottom(8)
        toolbar.set_border_width(10)

        self.draw_button = Gtk.Button()
        self.draw_button.set_label(self.draw_button_text())
        self.draw_button.set_sensitive(False)
        self.draw_button.connect("clicked", self.on_draw_button_clicked)
        toolbar.pack_start(self.draw_button, False, False, 0)
        self.tool_popover = self.build_tool_popover()

        self.color_button = Gtk.ColorButton()
        self.color_button.set_use_alpha(False)
        self.color_button.set_rgba(self.draw_color)
        self.color_button.set_title("Цвет карандаша")
        self.color_button.set_tooltip_text("Выбрать цвет карандаша")
        self.color_button.set_sensitive(False)
        self.color_button.connect("color-set", self.on_color_selected)
        toolbar.pack_start(self.color_button, False, False, 0)

        self.cursor_toggle = Gtk.ToggleButton(label="Скрыть курсор")
        self.cursor_toggle.set_active(True)
        self.cursor_toggle.set_sensitive(False)
        self.cursor_toggle.connect("toggled", self.on_cursor_toggle)
        toolbar.pack_start(self.cursor_toggle, False, False, 0)

        self.undo_button = Gtk.Button(label="Отменить")
        self.undo_button.set_sensitive(False)
        self.undo_button.connect("clicked", self.on_undo)
        toolbar.pack_start(self.undo_button, False, False, 0)

        self.done_button = Gtk.Button(label="Готово")
        self.done_button.get_style_context().add_class("suggested-action")
        self.done_button.set_sensitive(False)
        self.done_button.connect("clicked", self.on_done)
        toolbar.pack_start(self.done_button, False, False, 0)

        self.close_button = Gtk.Button(label="Закрыть")
        self.close_button.connect("clicked", lambda *_: Gtk.main_quit())
        toolbar.pack_start(self.close_button, False, False, 0)

        return toolbar

    def build_tool_popover(self):
        popover = Gtk.Popover.new(self.draw_button)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        box.set_margin_top(8)
        box.set_margin_bottom(8)
        box.set_margin_start(8)
        box.set_margin_end(8)
        for tool in TOOL_ORDER:
            button = Gtk.Button(label=TOOL_LABELS[tool])
            button.connect("clicked", self.on_tool_selected, tool, popover)
            box.pack_start(button, False, False, 0)
        popover.add(box)
        popover.set_position(Gtk.PositionType.BOTTOM)
        box.show_all()
        return popover

    def on_realize(self, *_args):
        self.cover_virtual_screen()

    def cover_virtual_screen(self):
        self.move(0, 0)
        self.resize(self.screen_width, self.screen_height)
        window = self.get_window()
        if window is not None:
            window.move_resize(0, 0, self.screen_width, self.screen_height)
        return False

    def apply_css(self):
        provider = Gtk.CssProvider()
        provider.load_from_data(
            b"""
            #toolbar {
                background: rgba(86, 86, 86, 0.94);
                border-radius: 16px;
                border: 1px solid rgba(185, 185, 185, 0.4);
                box-shadow: 0 8px 22px rgba(0, 0, 0, 0.35);
            }
            #toolbar button, #toolbar togglebutton, #toolbar menubutton > button {
                background: #6b6b6b;
                color: #f3f3f3;
                border-radius: 12px;
                border: 1px solid rgba(255, 255, 255, 0.08);
                padding: 8px 14px;
            }
            #toolbar button:hover, #toolbar togglebutton:hover, #toolbar menubutton > button:hover {
                background: #7b7b7b;
            }
            #toolbar togglebutton:checked {
                background: #4f4f4f;
            }
            .hint {
                color: #f3f3f3;
                background: rgba(50, 50, 50, 0.84);
                border-radius: 14px;
                padding: 12px 14px;
                font-size: 14px;
            }
            popover {
                background: #5f5f5f;
            }
            popover button {
                background: #777777;
                color: #ffffff;
                border-radius: 10px;
                padding: 8px 12px;
            }
            """
        )
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def draw_button_text(self):
        return f"Рисование: {TOOL_LABELS[self.current_tool]}"

    def update_toolbar(self):
        active = self.selection is not None
        self.draw_button.set_sensitive(True)
        self.color_button.set_sensitive(True)
        self.cursor_toggle.set_sensitive(active)
        self.done_button.set_sensitive(active)
        self.undo_button.set_sensitive(bool(self.annotations))
        self.draw_button.set_label(self.draw_button_text())

    def update_hint(self):
        if self.selection is None:
            self.hint_label.set_text(
                "Потяните мышью, чтобы выбрать область.\n"
                "Enter: скопировать и сохранить, Esc: закрыть."
            )
            return
        self.hint_label.set_text(
            "Подсказка: рисуйте внутри области.\n"
            "Кнопка рисования сверху, курсор можно скрыть."
        )

    def update_cursor(self):
        cursor_name = "crosshair" if self.selection is None else "default"
        display = Gdk.Display.get_default()
        cursor = Gdk.Cursor.new_from_name(display, cursor_name)
        window = self.get_window()
        if window is not None and cursor is not None:
            window.set_cursor(cursor)

    def get_pointer_position(self):
        display = Gdk.Display.get_default()
        if display is None:
            return (0, 0)
        seat = display.get_default_seat()
        if seat is None:
            return (0, 0)
        pointer = seat.get_pointer()
        if pointer is None:
            return (0, 0)
        _, x, y = pointer.get_position()
        return (x, y)

    def capture_root(self):
        root = Gdk.get_default_root_window()
        if root is None:
            return None
        width = root.get_width()
        height = root.get_height()
        return Gdk.pixbuf_get_from_window(root, 0, 0, width, height)

    def on_tool_selected(self, _button, tool, popover):
        self.current_tool = tool
        self.update_toolbar()
        popover.popdown()

    def on_draw_button_clicked(self, _button):
        self.tool_popover.popup()

    def on_color_selected(self, button):
        self.draw_color = button.get_rgba()

    def on_cursor_toggle(self, button):
        button.set_label("Скрыть курсор" if button.get_active() else "Показать курсор")

    def on_undo(self, *_args):
        if self.annotations:
            self.annotations.pop()
            self.preview_annotation = None
            self.update_toolbar()
            self.canvas.queue_draw()

    def on_done(self, *_args):
        self.export_selection_and_exit()

    def on_key_press(self, _widget, event):
        keyval = event.keyval
        state = event.state
        if keyval == Gdk.KEY_Escape:
            Gtk.main_quit()
            return True
        if keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            self.export_selection_and_exit()
            return True
        if keyval == Gdk.KEY_z and state & Gdk.ModifierType.CONTROL_MASK:
            self.on_undo()
            return True
        return False

    def on_button_press(self, _widget, event):
        if event.button != 1:
            return False

        x, y = event.x, event.y
        if self.selection and self.selection.contains(x, y):
            self.drag_action = "draw"
            self.preview_annotation = Annotation(
                tool=self.current_tool,
                start=(x, y),
                end=(x, y),
                color=self.rgba_tuple(self.draw_color),
                points=[(x, y)],
            )
        else:
            self.drag_action = "select"
            self.annotations.clear()
            self.preview_annotation = None
            self.selection_start = (x, y)
            self.selection = Rect(x, y, 0, 0)
            self.update_toolbar()
            self.update_hint()

        self.canvas.queue_draw()
        return True

    def on_motion_notify(self, _widget, event):
        if self.drag_action == "select" and self.selection_start is not None:
            start_x, start_y = self.selection_start
            self.selection = Rect(start_x, start_y, event.x - start_x, event.y - start_y)
            self.canvas.queue_draw()
        elif self.drag_action == "draw" and self.preview_annotation is not None:
            self.preview_annotation.end = (event.x, event.y)
            if self.preview_annotation.tool in ("pencil", "marker"):
                self.preview_annotation.points.append((event.x, event.y))
            self.canvas.queue_draw()
        return True

    def on_button_release(self, _widget, event):
        if event.button != 1:
            return False

        if self.drag_action == "select" and self.selection is not None:
            self.selection = self.selection.normalized()
            if self.selection.width < 8 or self.selection.height < 8:
                self.selection = None
            self.selection_start = None
            self.update_toolbar()
            self.update_hint()
            self.update_cursor()
        elif self.drag_action == "draw" and self.preview_annotation is not None:
            annotation = self.preview_annotation
            annotation.end = (event.x, event.y)
            if annotation.tool in ("pencil", "marker") and len(annotation.points) < 2:
                annotation = None
            if annotation is not None:
                self.annotations.append(annotation)
            self.preview_annotation = None
            self.update_toolbar()

        self.drag_action = None
        self.canvas.queue_draw()
        return True

    def on_draw(self, _widget, cr):
        Gdk.cairo_set_source_pixbuf(cr, self.screenshot, 0, 0)
        cr.paint()

        cr.set_source_rgba(0.08, 0.08, 0.08, 0.55)
        cr.rectangle(0, 0, self.screen_width, self.screen_height)
        cr.fill()

        if self.selection is not None:
            selection = self.selection.normalized()
            self.paint_selection(cr, selection)
            self.paint_selection_border(cr, selection)
            for annotation in self.annotations:
                self.paint_annotation(cr, annotation)
            if self.preview_annotation is not None:
                self.paint_annotation(cr, self.preview_annotation)

        return False

    def paint_selection(self, cr, selection):
        Gdk.cairo_set_source_pixbuf(cr, self.screenshot, 0, 0)
        cr.rectangle(selection.x, selection.y, selection.width, selection.height)
        cr.fill()

    def paint_selection_border(self, cr, selection):
        cr.set_source_rgba(0.95, 0.95, 0.95, 0.95)
        cr.set_line_width(2.0)
        cr.rectangle(selection.x + 1, selection.y + 1, selection.width - 2, selection.height - 2)
        cr.stroke()

    def paint_annotation(self, cr, annotation, offset_x=0.0, offset_y=0.0):
        tool = annotation.tool
        start_x, start_y = annotation.start
        end_x, end_y = annotation.end
        start_x -= offset_x
        start_y -= offset_y
        end_x -= offset_x
        end_y -= offset_y

        if tool == "marker":
            red, green, blue, _alpha = annotation.color
            cr.set_source_rgba(red, green, blue, 0.42)
            cr.set_line_width(16)
            cr.set_line_cap(cairo.LineCap.ROUND)
            self.paint_path(cr, annotation.points, offset_x, offset_y)
            return

        cr.set_source_rgba(*annotation.color)
        cr.set_line_width(4 if tool == "pencil" else 3)
        cr.set_line_cap(cairo.LineCap.ROUND)
        cr.set_line_join(cairo.LineJoin.ROUND)

        if tool == "pencil":
            self.paint_path(cr, annotation.points, offset_x, offset_y)
        elif tool == "square":
            rect = self.square_rect(start_x, start_y, end_x, end_y)
            cr.rectangle(rect.x, rect.y, rect.width, rect.height)
            cr.stroke()
        elif tool == "circle":
            rect = self.square_rect(start_x, start_y, end_x, end_y)
            radius = rect.width / 2.0
            cr.arc(rect.x + radius, rect.y + radius, radius, 0, 2 * math.pi)
            cr.stroke()
        elif tool == "arrow":
            self.paint_arrow(cr, start_x, start_y, end_x, end_y)

    def paint_path(self, cr, points, offset_x=0.0, offset_y=0.0):
        if len(points) < 2:
            return
        first_x, first_y = points[0]
        cr.move_to(first_x - offset_x, first_y - offset_y)
        for x, y in points[1:]:
            cr.line_to(x - offset_x, y - offset_y)
        cr.stroke()

    def paint_arrow(self, cr, x1, y1, x2, y2):
        angle = math.atan2(y2 - y1, x2 - x1)
        head = 18
        spread = math.radians(24)
        cr.move_to(x1, y1)
        cr.line_to(x2, y2)
        cr.stroke()
        cr.move_to(x2, y2)
        cr.line_to(
            x2 - head * math.cos(angle - spread),
            y2 - head * math.sin(angle - spread),
        )
        cr.move_to(x2, y2)
        cr.line_to(
            x2 - head * math.cos(angle + spread),
            y2 - head * math.sin(angle + spread),
        )
        cr.stroke()

    def paint_cursor(self, cr, x, y):
        cr.save()
        cr.translate(x, y)
        cr.move_to(0, 0)
        cr.line_to(0, 22)
        cr.line_to(6, 17)
        cr.line_to(10, 28)
        cr.line_to(14, 26)
        cr.line_to(10, 15)
        cr.line_to(18, 15)
        cr.close_path()
        cr.set_source_rgba(1.0, 1.0, 1.0, 0.96)
        cr.fill_preserve()
        cr.set_line_width(1.6)
        cr.set_source_rgba(0.05, 0.05, 0.05, 0.95)
        cr.stroke()
        cr.restore()

    def square_rect(self, x1, y1, x2, y2):
        side = min(abs(x2 - x1), abs(y2 - y1))
        width = side if x2 >= x1 else -side
        height = side if y2 >= y1 else -side
        return Rect(x1, y1, width, height).normalized()

    def rgba_tuple(self, rgba):
        return (rgba.red, rgba.green, rgba.blue, rgba.alpha)

    def export_selection_and_exit(self):
        if self.selection is None:
            return

        selection = self.selection.normalized()
        width = max(1, int(selection.width))
        height = max(1, int(selection.height))
        surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, width, height)
        cr = cairo.Context(surface)

        Gdk.cairo_set_source_pixbuf(cr, self.screenshot, -selection.x, -selection.y)
        cr.paint()

        for annotation in self.annotations:
            self.paint_annotation(cr, annotation, selection.x, selection.y)

        if not self.cursor_toggle.get_active():
            cursor_x = self.pointer_pos[0] - selection.x
            cursor_y = self.pointer_pos[1] - selection.y
            if 0 <= cursor_x <= width and 0 <= cursor_y <= height:
                self.paint_cursor(cr, cursor_x, cursor_y)

        output_path = self.output_path()
        surface.write_to_png(str(output_path))

        self.copy_image_to_clipboard(output_path, surface, width, height)

        self.notify_done(output_path)
        Gtk.main_quit()

    def copy_image_to_clipboard(self, output_path, surface, width, height):
        if os.environ.get("XDG_SESSION_TYPE") == "x11" and has_binary("xclip"):
            with open(os.devnull, "wb") as devnull:
                subprocess.Popen(
                    [
                        "/usr/bin/xclip",
                        "-selection",
                        "clipboard",
                        "-t",
                        "image/png",
                        "-i",
                        str(output_path),
                    ],
                    stdout=devnull,
                    stderr=devnull,
                    start_new_session=True,
                )
            return

        pixbuf = Gdk.pixbuf_get_from_surface(surface, 0, 0, width, height)
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        clipboard.set_image(pixbuf)
        clipboard.store()

    def output_path(self):
        pictures_dir = os.environ.get("XDG_PICTURES_DIR")
        if not pictures_dir:
            pictures_dir = subprocess.run(
                ["/usr/bin/xdg-user-dir", "PICTURES"],
                capture_output=True,
                text=True,
                check=False,
            ).stdout.strip()
        if not pictures_dir:
            pictures_dir = str(Path.home() / "Pictures")
        save_dir = Path(pictures_dir) / "Screenshots"
        save_dir.mkdir(parents=True, exist_ok=True)
        timestamp = subprocess.run(
            ["/usr/bin/date", "+%Y-%m-%d_%H-%M-%S"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.strip()
        return save_dir / f"screenshot_{timestamp}.png"

    def notify_done(self, output_path):
        if not has_binary("notify-send"):
            return
        subprocess.Popen(
            [
                "notify-send",
                "Скриншот готов",
                f"Файл сохранён в {output_path} и скопирован в буфер обмена.",
            ]
        )

    def fail_and_exit(self, message):
        if has_binary("notify-send"):
            subprocess.Popen(["notify-send", "Скриншот", message])
        else:
            print(message, file=sys.stderr)
        Gtk.main_quit()


def has_binary(binary: str):
    return subprocess.run(
        ["/usr/bin/env", "bash", "-lc", f"command -v {binary}"],
        capture_output=True,
        text=True,
        check=False,
    ).returncode == 0


def main():
    if os.environ.get("XDG_SESSION_TYPE") != "x11":
        if has_binary("notify-send"):
            subprocess.Popen(
                [
                    "notify-send",
                    "Новый интерфейс ждёт Xorg",
                    "Перелогиньтесь в Xorg, чтобы получить минимальный серый интерфейс.",
                ]
            )
        sys.exit(1)

    mode = sys.argv[1] if len(sys.argv) > 1 else "area"
    app = ScreenshotWindow(mode)
    app.present()
    Gtk.main()


if __name__ == "__main__":
    main()
